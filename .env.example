# Copy relevant values into .env (local dev, gitignored) or .env.production
# (committed — see the comment at the top of that file for why that's
# intentional here). Both are loaded automatically by Expo/Metro; no extra
# setup needed beyond having the file present.

# Base URL of the nur-backend API. Leave unset for local dev — defaults to
# http://localhost:3000, matching `npm run dev` in the backend repo.
EXPO_PUBLIC_API_BASE_URL=

# Optional — enables accounts / cross-device sync (see README.md's
# "Optional: cross-device sync" section). Leave both unset to stay fully
# local-only / guest-first.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
